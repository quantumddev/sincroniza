
# =========================================
# Backend: Python
# =========================================
# Caché de Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Entornos virtuales
venv/
.env/
.venv/
**/venv/
**/.venv/

# Herramientas de Python
.mypy_cache/
.pytest_cache/
*.log
*.tmp
coverage.xml
htmlcov/
.cache/
logs/


# =========================================
# DATA
# =========================================
data/settings.json
data/pending_sync.json
data/history/*.json
# Conservar los .gitkeep para que Git rastree las carpetas vacías
!data/.gitkeep
!data/history/.gitkeep


# =========================================
# Frontend: Node / React / Next.js
# =========================================
# Node modules
node_modules/

# Build / distribución
build/
frontend/dist/
.next/
*.spec

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
*.exe
dist/Contabilidad*
dist-ssr
*.local


# =========================================
# IDE / Editor
# =========================================
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.sw?

# =========================================
# OS específicos
# =========================================
.DS_Store
Thumbs.db
